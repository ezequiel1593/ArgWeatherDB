box_movil <- function(archivo, variable, n_period, lim = 0.9) {
  
  datos <- obtenerDatos(archivo)
  datos <- datos[,c('A','M','D',variable)]
  
  anios_unicos <- sort(unique(datos$A))
  anios_unicos <- anios_unicos[anios_unicos >= 1961] #Solo datos del período 1961-2024
  anios_unicos <- anios_unicos[anios_unicos <= 2024]
  
  periodos <- list()
  for (inicio in anios_unicos) {
    fin <- inicio + n_period - 1
    if (fin <= max(anios_unicos)) {
      periodo_datos <- datos %>%
        filter(A >= inicio & A <= fin)
      
      obs_completas <- sum(!is.na(periodo_datos[,c(variable)]))
      prop_completas <- obs_completas / nrow(periodo_datos)
      
      if (prop_completas >= lim) {
        periodo_datos <- periodo_datos %>%
          mutate(periodo = paste0(inicio,'-',fin))
        periodos[[length(periodos) + 1]] <- periodo_datos
      } else {
        periodo_datos <- periodo_datos %>%
          mutate(periodo = paste0(inicio,'-',fin))
        datos[,c(variable)] <- NA
        periodos[[length(periodos) + 1]] <- periodo_datos
      }
    }
  }
  df_periodos <- bind_rows(periodos)
  colnames(df_periodos) <- c('A','M','D','Temp','Periodo')
  
  graf <- ggplot(df_periodos, aes(x = Periodo, y = Temp)) +
    stat_boxplot(geom = 'errorbar') +
    geom_boxplot() +
    labs(y = 'Temperatura (°C)',
         title = paste0('Temperatura ',
                        ifelse(variable == 'Tmin','mínima','máxima'),
                        ' en ',obtenerNombreBreve(archivo))) +
    theme(axis.text.x = element_text(angle = 90) )
  
  return(graf)
  
}

