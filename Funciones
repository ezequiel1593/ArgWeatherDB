tabla_mensual <- function(archivo, variable, extra = FALSE) {
  datos <- obtenerDatos(archivo)
  
  if (variable == "tnm") {
    tabla <- tapply(datos$Tmin, list(datos$A, datos$M),
                    function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, round(mean(x, na.rm=T),1), NA ) } )
  } else if (variable == "txm") {
    tabla <- tapply(datos$Tmax, list(datos$A, datos$M),
                    function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, round(mean(x, na.rm=T),1), NA ) } )
  } else if (variable == "tnn") {
    tabla <- tapply(datos$Tmin, list(datos$A, datos$M),
                    function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, min(x, na.rm=T), NA ) } )
  } else if (variable == "tnx") {
    tabla <- tapply(datos$Tmin, list(datos$A, datos$M),
                    function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, max(x, na.rm=T), NA ) } )
  } else if (variable == "txn") {
    tabla <- tapply(datos$Tmax, list(datos$A, datos$M),
                    function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, min(x, na.rm=T), NA ) } )
  } else if (variable == "txx") {
    tabla <- tapply(datos$Tmax, list(datos$A, datos$M),
                    function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, max(x, na.rm=T), NA ) } )
  }
  
  colnames(tabla) <- c("Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic")
  
  nombre_parametro <- switch(variable,"tnm"="Temperatura mínima media",
                             "txm"="Temperatura máxima media",
