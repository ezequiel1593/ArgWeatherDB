records <- function(archivo, anio) {
  
  datos <- obtenerDatos(archivo)
  datos$Fecha <- as.Date(paste0(datos$A, "-", datos$M, "-", datos$D), format = "%Y-%m-%d")
  
  primer_anio <- datos[2, 1]
  ultimo_anio <- datos[nrow(datos), 1]
  
  datos <- subset(datos, A >= anio)
  
  # Inicializar listas para almacenar resultados
  records_minimos <- aggregate(cbind(Tmin, Tmax) ~ M, data = datos, FUN = min, na.rm = TRUE)
  records_maximos <- aggregate(cbind(Tmin, Tmax) ~ M, data = datos, FUN = max, na.rm = TRUE)
  
  fechas_tnn <- character(12)
  fechas_txn <- character(12)
  fechas_tnx <- character(12)
  fechas_txx <- character(12)
  
  for (mes in 1:12) {
    subdatos <- subset(datos, M == mes)
    
    # Manejar casos donde no hay datos para el mes
    if (nrow(subdatos) == 0) {
      fechas_tnn[mes] <- NA
      fechas_txn[mes] <- NA
      fechas_tnx[mes] <- NA
      fechas_txx[mes] <- NA
      next
    }
    
    # Tnn: Fecha del mínimo de Tmin
    posicion_fecha_tnn <- which(subdatos$Tmin == records_minimos$Tmin[records_minimos$M == mes])
    fechas_tnn[mes] <- if (length(posicion_fecha_tnn) > 0) {
      paste(subdatos$Fecha[posicion_fecha_tnn], collapse = "\n")
    } else {
      NA
    }
    
    # Txn: Fecha del mínimo de Tmax
    posicion_fecha_txn <- which(subdatos$Tmax == records_minimos$Tmax[records_minimos$M == mes])
    fechas_txn[mes] <- if (length(posicion_fecha_txn) > 0) {
      paste(subdatos$Fecha[posicion_fecha_txn], collapse = "\n")
    } else {
      NA
    }
    
    # Tnx: Fecha del máximo de Tmin
    posicion_fecha_tnx <- which(subdatos$Tmin == records_maximos$Tmin[records_maximos$M == mes])
    fechas_tnx[mes] <- if (length(posicion_fecha_tnx) > 0) {
      paste(subdatos$Fecha[posicion_fecha_tnx], collapse = "\n")
    } else {
      NA
    }
    
    # Txx: Fecha del máximo de Tmax
    posicion_fecha_txx <- which(subdatos$Tmax == records_maximos$Tmax[records_maximos$M == mes])
    fechas_txx[mes] <- if (length(posicion_fecha_txx) > 0) {
      paste(subdatos$Fecha[posicion_fecha_txx], collapse = "\n")
    } else {
      NA
    }
  }
  
  # Crear el data.frame asegurando 12 filas
  tabla <- data.frame(
    Mes = c("Ene", "Feb", "Mar", "Abr", "May", "Jun", "Jul", "Ago", "Sep", "Oct", "Nov", "Dic"),
    Tnn = records_minimos$Tmin[match(1:12, records_minimos$M)],
    Fecha_Tnn = fechas_tnn,
    Tnx = records_maximos$Tmin[match(1:12, records_maximos$M)],
    Fecha_Tnx = fechas_tnx,
    Txn = records_minimos$Tmax[match(1:12, records_minimos$M)],
    Fecha_Txn = fechas_txn,
    Txx = records_maximos$Tmax[match(1:12, records_maximos$M)],
    Fecha_Txx = fechas_txx
  )
  
  # Reemplazar posibles NA en valores numéricos
  tabla$Tnn[is.na(tabla$Tnn)] <- NA
  tabla$Tnx[is.na(tabla$Tnx)] <- NA
  tabla$Txn[is.na(tabla$Txn)] <- NA
  tabla$Txx[is.na(tabla$Txx)] <- NA
  
  titulo <- paste0('Récords en ', sub(pattern = "\\s*\\(.*" ,replacement = "" ,x = archivo),' ',
                   ifelse(anio<primer_anio,primer_anio,anio),'-',ultimo_anio )
  
  mytabl <- tabla |> gt() |>
    tab_header(title = md(paste0("**", titulo, "**"))) |>
    fmt_number(columns = c(2, 4, 6, 8), decimals = 1) |>
    tab_style(style = cell_text(weight = "bold"), locations = cells_column_labels()) |>
    tab_style(style = cell_text(weight = "bold"), locations = cells_body(columns = 1)) |>
    cols_width(c(3, 5, 7, 9) ~ px(95)) |>
    data_color(
      columns = c(2, 4, 6, 8),
      method = "numeric",
      palette = c("#8000ff", "#62be7a", "#ffeb84", "#f8696b"),
      domain = c(-40, 50)
    )
  
  return(mytabl)
}

umbrales <- function(archivo, comparacionUmbral, umbral, mes) {
  datos <- obtenerDatos(archivo)
  
  datos_del_mes <- subset(datos, M == mes)
  
  if (comparacionUmbral == "Tmin <=") {
    tabla <- subset(datos_del_mes, Tmin <= umbral)
  } else if (comparacionUmbral == "Tmin >=") {
    tabla <- subset(datos_del_mes, Tmin >= umbral)
  } else if (comparacionUmbral == "Tmax <=") {
    tabla <- subset(datos_del_mes, Tmax <= umbral)
  } else if (comparacionUmbral == "Tmax >=") {
    tabla <- subset(datos_del_mes, Tmax >= umbral)
  }
  
  titulo <- paste0('Dias con ',comparacionUmbral,umbral,'°C en ',substr(archivo, 1, nchar(archivo) - 4),'.')
  
  mytabl <- as.data.frame(tabla) |> gt() |>
    tab_header(title = md(paste0('**', titulo , '**'))) |>
    fmt_number(columns = 4:5,decimals = 1) |>
    cols_width(everything() ~ px(67)) |>
    tab_options(container.width = px(67*5)) |>
    opt_interactive(use_pagination = F,use_search = F)
  
  return(mytabl)
}

frecuenciaMensualNA <- function(x, comparacion, umbral) {
  cantidadNA <- sum(is.na(x))
  if (cantidadNA > 5) {resultado <- NA
  } else {
    if (comparacion == '>=') {
      resultado <- sum(x >= umbral,na.rm = TRUE)
    } else if (comparacion == '<=') {
      resultado <- sum(x <= umbral,na.rm = TRUE)
    }
  }
  return(resultado)
}
