tablaAnual <- function(archivo,anio){
  
  datos <- obtenerDatos(archivo)
  subdatos <- subset(datos, A==anio)
  
  #CAMBIAR ESTO AL FINALIZAR EL AÑO 2025!!
  if (anio == 2025) {
    fechas_completas <- tidyr::expand_grid(
      fecha = seq(as.Date('2025-01-01'), as.Date('2025-12-31'), by = 'day') ) %>%
      mutate(A = year(fecha), M = month(fecha), D = day(fecha)) %>%
      select(A,M,D) %>%
      mutate_all(as.integer)
    
    subdatos <- fechas_completas %>%
      left_join(subdatos, by = c('A','M','D'))
  }
  
  if (NROW(subdatos) == 0) {
    tabla <- data.frame("SD"= c("Sin datos para este año."))
    mytabl <- gt(data = tabla)
  } else {
    
    dividido <- split(subdatos[c('D','Tmin','Tmax')], subdatos$M)
    tablaFinal <- as.data.frame(dividido[[1]])
    for (i in 2:12) {
      df_a_agregar <- as.data.frame(dividido[[i]])
      tablaFinal <- merge(tablaFinal, df_a_agregar, by= 'D', all = T) }
    row.names(tablaFinal) <- tablaFinal[,1]
    colnames(tablaFinal) <- c('Dia',letters[1:24])
    
    titulo <- paste0('Datos para ',obtenerNombreBreve(archivo), ', año ',anio)
    
    mytabl <- tablaFinal |> gt() |>
      tab_header(title = md(paste0('**', titulo , '**'))) |>
      tab_style(style = list(cell_text(weight = 'bold')),locations = cells_body(columns = 1)) |>
      data_color(columns = c(2:25),method = 'numeric', palette = c("#8000ff","#62be7a","#ffeb84","#f8696b"), domain = c(-40,50))
    
    meses <- c("Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic")
    
    for (i in 1:12) {
      
      inic <- i*2 ; fin <- (i*2)+1
      
      mytabl <- mytabl |>
        tab_spanner(label = meses[i], columns = inic:fin)
      
      mytabl <- mytabl |>
        cols_label( !!letters[((i*2)-1)] := 'Tmin', !!letters[(i*2)] := 'Tmax')
    }
    
  } #ELSE
  
  return(mytabl)
}

