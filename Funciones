mediaMensualNA <- function(x) {
  cantidadNA <- sum(is.na(x))
  if (cantidadNA >5) {resultado <- NA
  } else {resultado <- mean(x, na.rm=TRUE)}
  return(resultado)
}

obtenerDatos <- function(archivo){
  
  datos <- read.table(here("Data",archivo),
                      header = TRUE,
                      #col.names = c("A","M","D","Tmax","Tmin"),
                      na.strings = "",
                      sep = '\t')
  
  datos$Tmax <- as.numeric(datos$Tmax)
  datos$Tmin <- as.numeric(datos$Tmin)
  
  return(datos)
}

obtener_mytable <- function (tabla, titulo, colores, dominio, interactivo=FALSE) {
  
  mytabl <- tabla |> gt() |>
    tab_header(title = md(paste0('**', titulo, '**'))) |>
    cols_add(Año = rownames(tabla),.before = 'Ene') |>
    fmt_number(columns = 2:13,decimals = 1) |>
    tab_style(style = cell_text(weight = 'bold'),locations = cells_column_labels()) |>
    tab_style(style = list(cell_text(weight = 'bold')),locations = cells_body(columns = 1)) |>
    cols_width(c(2:13) ~ px(63)) |>
    cols_width(Año ~ px(54)) |>
    data_color(columns = c(2:13),method = 'numeric', palette = colores, domain = dominio) |>
    tab_options(container.width = px(810))
  
  if (interactivo == TRUE) { mytabl <- mytabl |> opt_interactive(use_pagination = F,use_search = F) }
  
  return(mytabl)
}

