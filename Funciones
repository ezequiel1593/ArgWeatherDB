distribucion <- function(archivo, variable) {
  
  datos <- obtenerDatos(archivo)
  datos <- datos %>%
    filter(A >= 1991 & A <=2020)
  
  datos <- datos[[variable]]
  
  n <- sum(!is.na(datos))
  n_teorico <- length(seq(as.Date('1991-01-01'),as.Date('2020-12-31'),by = 'day'))
  pctj <- round((n/n_teorico)*100,1)
  
  asim <- round(moments::skewness(datos,na.rm = TRUE),2)
  mediana <- median(datos, na.rm = TRUE)
  media <- mean(datos, na.rm = TRUE)
  
  lineas <- data.frame(
    valor = c(mediana, media),
    tipo = c("Mediana", "Media")
  )
  
  set_blanket()
  f <- gg_density(data = as.data.frame(datos), x = datos, #x = !!rlang::sym(variable), col = periodo,
                  alpha = 0.4, x_label = paste0(variable,' (°C)'), y_label = 'Density',
                  title = paste0(obtenerNombreBreve(archivo))) +
    geom_vline(data = lineas, aes(xintercept = valor, color = tipo), linetype = 'dashed') +
    scale_color_manual(values = c("Mediana" = "blue", "Media" = "red")) +
    theme(plot.title = element_text(hjust = 0.5),
          legend.position = 'bottom', legend.direction = 'horizontal', legend.title = element_blank()) +
    labs(caption = paste0('Pctj: ',pctj,'; Asim: ',asim,'; mediana: azul; media: rojo'))
  
  return(f)
}

busqueda_inconsistencias <- function(archivo, variable) {
  
  datos <- obtenerDatos(archivo)
  
  if (variable == 'minima') {
    
    #Mínima superior a la máxima del día precedente
    datos_lagueados_max <- datos %>%
      mutate(max_ant = lag(Tmax)) %>%
      mutate(dif = Tmin - max_ant) %>%
      filter(dif > 0)
    
    return(datos_lagueados_max)
    
  } else {
    
    #Máxima inferior a la mínima del día precedente
    datos_lagueados_min <- datos %>%
      mutate(min_ant = lag(Tmin)) %>%
      mutate(dif = Tmax - min_ant) %>%
      filter(dif < 0)
    
    return(datos_lagueados_min)
    
  }
}

#Se estudia como cambia la correlación entre anomalías de 2 series
#Comparar correlaciones con el paquete cocor!!
#http://comparingcorrelations.org/
evolucion_correl <- function(estacion1, estacion2, variable, n_anios, tipocor) {
  
  datos_tabla1 <- anomalias(estacion1,variable,9)$tabla
  datos_tabla1$Anio <- as.integer(rownames(datos_tabla1))
  datos1 <- datos_tabla1 %>%
    pivot_longer(cols = -Anio, names_to = 'Mes', values_to = paste0(variable,1))
  
  datos_tabla2 <- anomalias(estacion2,variable,9)$tabla
  datos_tabla2$Anio <- as.integer(rownames(datos_tabla2))
  datos2 <- datos_tabla2 %>%
    pivot_longer(cols = -Anio, names_to = 'Mes', values_to = paste0(variable,2))
  
  if(datos1$Anio[1] < datos2$Anio[1]) { 
    datos_conjuntos <- datos1 %>% right_join(datos2, by = c('Anio','Mes'))
  } else {
    datos_conjuntos <- datos1 %>% left_join(datos2, by = c('Anio','Mes'))
  }
  
  seq_anios <- datos_conjuntos$Anio[1]:(2020 - n_anios + 1)
  
  serieFinal <- data.frame(Periodo = integer(), correl = numeric(), p_value = numeric(), n = integer())
  
  for (anio in seq_anios) {
    subdatos <- datos_conjuntos %>% filter(between(Anio,anio,anio + n_anios - 1))
    resultado_cor <- cor.test(x = subdatos[[3]], y = subdatos[[4]], use = "complete.obs", method = tipocor)
    n <- sum(complete.cases(subdatos[3:4]))
    serieFinal <- rbind(serieFinal, data.frame('Periodo'= paste0(anio,'-',anio + n_anios - 1),
                                               'correl' = round(resultado_cor$estimate,2),
                                               'p_value' = round(resultado_cor$p.value,2),
                                               'n'=n) ) }
  colnames(serieFinal) <- c('Periodo','correl','p_value','n')
  print(serieFinal)
  
  serieFinal$PeriodoNum <- as.numeric(sub("-.*", "", serieFinal$Periodo))
  set_blanket()
  f <- ggplot(data = serieFinal) +
    geom_step(aes(x = PeriodoNum, y = correl)) +
    geom_point(aes(x = PeriodoNum, y = (n/400) ), size = 3) +
    scale_y_continuous(name = "Correl", sec.axis = sec_axis( trans=~.*400 , name="n") ) +
    labs(x = paste0('Año de inicio del período de ',n_anios,' años'),
         title = paste0('Correlación (',tipocor,') móvil ',obtenerNombreBreve(estacion1),' - ',obtenerNombreBreve(estacion2)),
         subtitle = paste0('Anomalías de la ',variable, ' respecto al período 1991-2020.') )
  return(f)
}

