    cols_width(everything() ~ px(67)) |>
    tab_options(container.width = px(67*5)) |>
    opt_interactive(use_pagination = F,use_search = F)
  
  return(list('mytable'= mytabl,
              'tabla' = tabla ) )
}

rachas <- function(archivo, variable, comparacion, umbral, duracion_minima) {
  
  datos <- obtenerDatos(archivo)
  datos$Fecha <- as.Date(paste0(datos$A,'-',datos$M,'-',datos$D), format = '%Y-%m-%d')
  
  subdatos <- datos[,c('Fecha',variable)]
  
  if (comparacion == '>=') {
    datos$cumple_umbral <- subdatos[,2] >= umbral
  } else if (comparacion == '<=') {
    datos$cumple_umbral <- subdatos[,2] <= umbral
  }
  
  tabla <- rle(datos$cumple_umbral)
  
  tablaDF <- data.frame('Extension' = tabla$lengths, 'valor' = tabla$values,
                        'start' = cumsum(c(1, tabla$lengths[-length(tabla$lengths)] )),
                        'end' = cumsum(tabla$lengths) )
  
  tablaDF$Fecha_inicial <- datos$Fecha[tablaDF$start]
  tablaDF$Fecha_final <- datos$Fecha[tablaDF$end]
  
  tabla_final <- subset(tablaDF, (valor == TRUE) & (Extension >= duracion_minima) )
  tabla_final <- tabla_final[order(tabla_final$Extension,decreasing = T),]
  tabla_final <- tabla_final[,c(1,5,6)]
  
  return(tabla_final)
  
}

