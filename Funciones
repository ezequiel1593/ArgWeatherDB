anomalias <- function(archivo, variable, periodo) {
  
  tabla_valores_normales <- valores_normales(archivo,periodo)$tabla
  
  datos <- obtenerDatos(archivo)
  
  tabla <- tapply(datos[[ variable ]], list(datos$A, datos$M),
                  function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, round(mean(x, na.rm=T),1), NA ) } )
  
  if (variable == "Tmin") {
    valoresNormales <- tabla_valores_normales$Tnm
  } else if (variable == "Tmax") {
    valoresNormales <- tabla_valores_normales$Txm
  }
  
  if (is.null(valoresNormales)) { 
    tabla <- data.frame("SD"= c("Sin valores normales para este período."))
    mytabl <- gt(data = tabla)
    
    return(list("mytabl"= mytabl,
                "tabla"= NULL) )
    }
  
  for (fila in 1:nrow(tabla)) { tabla[fila,] <- tabla[fila,] - valoresNormales }
  
  colnames(tabla) <- c("Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic")
  
  nombre_parametro <- switch(variable,"Tmin"="Temperatura mínima media",
                             "Tmax"="Temperatura máxima media")
  
  año_inicio <- switch(periodo,1911,1921,1931,1941,1951,1961,1971,1981,1991)
  año_final <- switch(periodo,1940,1950,1960,1970,1980,1990,2000,2010,2020)
  
  titulo <- paste0('Anomalía de la ',nombre_parametro,' en ',
                   substrRight(archivo),' respecto al período ',año_inicio,'-',año_final,'.')
  
  paleta <- scales::col_numeric(palette = c("#3333ff","#ffffff","#cc0000"),domain = c(-7,7))
  
  mytabl <- as.data.frame(tabla) |> gt() |>
    tab_header(title = md(paste0('**', titulo, '**'))) |>
    cols_add(Año = rownames(tabla),.before = 'Ene') |>
    fmt_number(columns = 2:13,decimals = 1) |>
    tab_style(style = cell_text(weight = 'bold'),locations = cells_column_labels()) |>
    tab_style(style = list(cell_text(weight = 'bold')),locations = cells_body(columns = 1)) |>
    cols_width(c(2:13) ~ px(63)) |>
    cols_width(Año ~ px(54)) |>
    data_color(columns = 2:13,
               colors = function(x) {case_when(is.na(x) ~ "gray",
                                               x >= 7 ~"#cc0000",
                                               x <= -7 ~ "#3333ff",
                                               TRUE ~ paleta(x))} ) |>
    tab_options(container.width = px(810)) |>
    opt_interactive(use_pagination = F,use_search = F)

  return(list("mytabl"= mytabl,
              "tabla"= as.data.frame(tabla)) )
  
}

anomalia_estandarizada <- function(archivo,variable,periodo) {
  
  tabla_anomalias <- anomalias(archivo,variable,periodo)$tabla
  
  if (is.null(tabla_anomalias)) { 
    tabla <- data.frame("SD"= c("Sin valores normales para este período."))
    mytabl <- gt(data = tabla)
    
    return(list("mytabl"= mytabl,
                "tabla"= NULL) )
  }
  
  #El desvío estándar de las anomalías es igual al desvío estándar de los valores 'crudos'
  anio_inicio <- ((periodo -1)*10) + 1911 ; anio_final <- anio_inicio + 29
  datos_periodo <- tabla_anomalias[row.names(tabla_anomalias) >= anio_inicio & row.names(tabla_anomalias) <= anio_final,]
  desvios_normales <- apply(datos_periodo,MARGIN = 2,
                            FUN = function(x) {ifelse(sum(!is.na(x)) < 27,
                                                      NA,
                                                      sd(x,na.rm = TRUE))})
  
  tablaFinal <- t(apply(tabla_anomalias,MARGIN = 1,
                        FUN = function(x) round(x/desvios_normales,1)))
  
  nombre_parametro <- switch(variable,"Tmin"="Temperatura mínima media",
                             "Tmax"="Temperatura máxima media")
  
  titulo <- paste0('Anomalias estandarizadas de la ',nombre_parametro,' en ',
                   obtenerNombreBreve(archivo),' respecto al período ',anio_inicio,'-',anio_final,'.')
  
  mytabl <- obtener_mytable(as.data.frame(tablaFinal),titulo,
                            colores = c("#3333ff","#ffffff","#cc0000"),dominio = c(-7,7),
                            interactivo = TRUE)
  
  return(list("mytabl"= mytabl,
              "tabla"= as.data.frame(tablaFinal)) )
}

percentiles <- function(archivo, periodo, variable) {
  
  año_inicio <- switch(periodo,1911,1921,1931,1941,1951,1961,1971,1981,1991)
  año_final <- switch(periodo,1940,1950,1960,1970,1980,1990,2000,2010,2020)
  
  datos <- obtenerDatos(archivo)
  subdatos <- subset(datos, (A >= año_inicio) & (A <= año_final) )
  
  if (NROW(subdatos) == 0) {
    
    tabla <- data.frame("SD"= c("Sin datos para este período."))
    mytabl <- gt(data = tabla)
    
  } else {
    
    myperc <- tapply(subdatos[[variable]], list(subdatos$M),
                   function(x) round(quantile(x, probs= seq(0.05,0.95,0.05), na.rm = T),1) )
  
    tabla <- data.frame(do.call(cbind, myperc))
    rownames(tabla) <- seq(5,95,5)
    colnames(tabla) <- c("Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic")
    
    #Cantidad de datos suficiente
    cantidad_total_dias_teorica <- c(930,848,930,900,930,900,930,930,900,930,900,930)
    for (i in (1:12)) {
      control_subset <- subset(subdatos, M == i)
      if ( sum(!is.na(control_subset[[variable]])) < (cantidad_total_dias_teorica[i]*0.85) ) {
        tabla[,i] <- NA } }
    
    #ACÁ EMPIEZO CON MYTABL
    nombre_parametro <- switch(variable,"Tmin"="temperatura mínima", "Tmax"="temperatura máxima")
    
    titulo <- paste0('Percentiles de la ',nombre_parametro,' en ',
                     obtenerNombreBreve(archivo),', período ',año_inicio,'-',año_final,'.')
    
    mytabl <- tabla |> gt() |>
      tab_header(title = md(paste0('**', titulo, '**'))) |>
      fmt_number(columns = 1:12,decimals = 1) |>
      cols_add(P = seq(5,95,5),.before = 'Ene') |>
      tab_style(style = list(cell_text(weight = 'bold')),locations = cells_column_labels()) |>
      tab_style(style = list(cell_text(weight = 'bold')),locations = cells_body(columns = 1)) |>
      cols_width(c(2:13) ~ px(50)) |>
      cols_width(P ~ px(30)) |>
      data_color(columns = 2:13,method = 'numeric',palette = c("#8000ff","#62be7a","#ffeb84","#f8696b"),domain = c(-40,50))
    
  } #Llave del else
  
  return(list("mytabl"=mytabl,
              "tabla"=tabla) )
  
}

