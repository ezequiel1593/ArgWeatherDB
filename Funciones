               'Oto'= pmax(Mar,Abr,May),
               'Inv'= pmax(Jun,Jul,Ago),
               'Pri'= pmax(Sep,Oct,Nov),
               'Anu'= pmax(Ene,Feb,Mar,Abr,May,Jun,Jul,Ago,Sep,Oct,Nov,Dic)) %>%
        select(-Dic_Ant)
    }
    
    nombres_viejos <- names(tabla)[1:18]
    nombres_nuevos <- substr(nombres_viejos,1,1)
    
    mytabl <- tabla |> gt() |>
      tab_header(title = md(paste0('**', titulo, '**'))) |>
