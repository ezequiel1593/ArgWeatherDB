corrDatosDiarios <- function(archivo1, archivo2, anio_inicio, anio_final){
  
  datos_estacion1 <- obtenerDatos(archivo1)
  datos_estacion1 <- subset(datos_estacion1, (A >= anio_inicio) & (A <= anio_final) )
  datos_estacion2 <- obtenerDatos(archivo2)
  datos_estacion2 <- subset(datos_estacion2, (A >= anio_inicio) & (A <= anio_final) )
  
  if (length(rownames(datos_estacion1)) == 0 ) {
    tabla <- data.frame("Datos insuficientes"= c("La estación 1 no cuenta con datos suficientes."))
    mytabl <- datatable(tabla, rownames = FALSE, options = list (dom = 't' ) )
    return(mytabl)
  }
  
  if (length(rownames(datos_estacion2)) == 0 ) {
    tabla <- data.frame("Datos insuficientes"= c("La estación 2 no cuenta con datos suficientes."))
    mytabl <- datatable(tabla, rownames = FALSE, options = list (dom = 't' ) )
    return(mytabl)
  }
  
  tablaDatos <- merge(datos_estacion1,datos_estacion2,by = c('A','M','D'))
  colnames(tablaDatos) <- c('A','M','D','Tmax1','Tmin1','Tmax2','Tmin2')
  
  correlacionesMin <- by(tablaDatos[,c('Tmin1','Tmin2')], tablaDatos$M, function(x) cor(x[,1],x[,2], use = "complete.obs") )
  correlacionesMax <- by(tablaDatos[,c('Tmax1','Tmax2')], tablaDatos$M, function(x) cor(x[,1],x[,2], use = "complete.obs") )
  nTmin <- by(tablaDatos[,c('Tmin1','Tmin2')], tablaDatos$M, function(x) sum(complete.cases(x[,1],x[,2])) )
  nTmax <- by(tablaDatos[,c('Tmax1','Tmax2')], tablaDatos$M, function(x) sum(complete.cases(x[,1],x[,2])) )

  resumen <- data.frame('Mes'= 1:12,
                        'corTmin'= as.numeric(correlacionesMin),
                        'nTmin' = as.integer(nTmin),
                        'Máximas'= as.numeric(correlacionesMax),
                        'nTmax' = as.integer(nTmax) )
  
  mytabl <- resumen |> gt() |>
    fmt_number(columns = c(2,4),decimals = 2) |>
    tab_style(style = list(cell_text(weight = 'bold')),locations = cells_column_labels()) |>
    tab_style(style = list(cell_text(weight = 'bold')),locations = cells_body(columns = 1))

  return(mytabl)
}

