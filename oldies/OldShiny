valores_normales <- function(archivo, periodo) {
  
  año_inicio <- switch(periodo,1911,1921,1931,1941,1951,1961,1971,1981,1991)
  año_final <- switch(periodo,1940,1950,1960,1970,1980,1990,2000,2010,2020)
  
  datos <- obtenerDatos(archivo)
  
  subdatos <- subset(datos, (A >= año_inicio) & (A <= año_final))
  
  cantidad_total_dias_teorica <- c(930,848,930,900,930,900,930,930,900,930,900,930)
  #(La cantidad teórica en febrero varía entre 847 y 848, desprecio esta variación)
  
  if (NROW(subdatos) == 0) {
    tabla <- data.frame("SD"= c("Sin datos para este período."))
    mytabl <- gt(data = tabla)
  } else {
    cantidad_total_dias_efectiva <- aggregate(subdatos, by=list(subdatos$M), function(x) sum(!is.na(x)) )
    porcentaje_efectivo_Tmin <- (cantidad_total_dias_efectiva$Tmin/cantidad_total_dias_teorica)*100
    porcentaje_efectivo_Tmax <- (cantidad_total_dias_efectiva$Tmax/cantidad_total_dias_teorica)*100
    
    ValoresMedios <- aggregate(subdatos, by=list(subdatos$M), function(x) mean(x, na.rm= TRUE) )
    
    tabla <- data.frame("Mes"= c("Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic"),
                        "Tnm"= round(ValoresMedios$Tmin, digits = 1),
                        "Txm"= round(ValoresMedios$Tmax, digits = 1))
    
    for (mes in 1:12) {
      if (porcentaje_efectivo_Tmin[mes] < 85) {tabla[mes,2] <- NA}
      if (porcentaje_efectivo_Tmax[mes] < 85) {tabla[mes,3] <- NA}
    }
    
    tnn <- tapply(subdatos$Tmin, list(subdatos$A, subdatos$M), function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, min(x, na.rm=T), NA ) } )
    
    if (length(tnn[,1]) != 30) {
      
      tabla$Tnn <- tabla$Txn <- tabla$Tnx <- tabla$Txx <- tabla$DSn <- tabla$DSx <- rep(NA,12)
      
    } else {
      
      tabla$Tnn <- apply(tnn,2, function(x) { ifelse(sum(is.na(x)) <= 4, round(mean(x, na.rm=T),1),NA) } )
      
      txn <- tapply(subdatos$Tmax, list(subdatos$A, subdatos$M), function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, min(x, na.rm=T), NA ) } )
      tabla$Txn <- apply(txn,2, function(x) { ifelse(sum(is.na(x)) <= 4, round(mean(x, na.rm=T),1),NA) } )
      
      tnx <- tapply(subdatos$Tmin, list(subdatos$A, subdatos$M), function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, max(x, na.rm=T), NA ) } )
      tabla$Tnx <- apply(tnx,2, function(x) { ifelse(sum(is.na(x)) <= 4, round(mean(x, na.rm=T),1),NA) } )
      
      txx <- tapply(subdatos$Tmax, list(subdatos$A, subdatos$M), function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, max(x, na.rm=T), NA ) } )
      tabla$Txx <- apply(txx,2, function(x) { ifelse(sum(is.na(x)) <= 4, round(mean(x, na.rm=T),1),NA) } )
      
      dsn <- tapply(subdatos$Tmin, list(subdatos$A, subdatos$M), function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, sd(x, na.rm=T), NA ) } )
      tabla$DSn <- apply(dsn,2, function(x) { ifelse(sum(is.na(x)) <= 4, round(mean(x, na.rm=T),1),NA) } )
      
      dsx <- tapply(subdatos$Tmax, list(subdatos$A, subdatos$M), function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, sd(x, na.rm=T), NA ) } )
      tabla$DSx <- apply(dsx,2, function(x) { ifelse(sum(is.na(x)) <= 4, round(mean(x, na.rm=T),1),NA) } )
      
    }
    
    titulo <- paste0('Valores normales de la estación ',obtenerNombreBreve(archivo),
                     ', período ',año_inicio,'-',año_final,'.')
    
    mytabl <- tabla |> gt() |>
      tab_header(title = md(paste0('**', titulo, '**'))) |>
      fmt_number(columns = 2:9,decimals = 1) |>
      tab_style(style = list(cell_text(weight = 'bold')),locations = cells_column_labels()) |>
      tab_style(style = list(cell_text(weight = 'bold')),locations = cells_body(columns = 1)) |>
      cols_width(c(2:9) ~ px(50))
    
  } #Llave del else
  
  return(list("mytabl"=mytabl,
              "tabla"= tabla) )
  
}

amplitudTermicaMensual <- function(archivo, opcion = 'media') {
  
  if (opcion == 'media') {
    
    datos <- obtenerDatos(archivo)
    
    datos$amplitud <- datos$Tmax - datos$Tmin
    
    tabla <- tapply(datos$amplitud, list(datos$A, datos$M),
                    function(x) { ifelse( (sum(is.na(x)) / length(x)) <0.15, round(mean(x, na.rm=T),1), NA ) } )
    
    colnames(tabla) <- c("Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic")
    
    titulo <- paste0('Amplitud térmica media mensual en ',substr(archivo, 1, nchar(archivo) - 4),'.')
    
    mytabl <- obtener_mytable(as.data.frame(tabla), titulo,
                              colores = c("#008000","#ffffff","#cc0000"), dominio = c(0,25),
                              interactivo=TRUE)
    
    return(list("mytabl"= mytabl,
                "tabla"= tabla) )
    
  } else if (opcion == 'absoluta') {
    
    minimas_absolutas <- tabla_mensual(archivo, 'tnn')$tabla
    maximas_absolutas <- tabla_mensual(archivo, 'txx')$tabla
    
    amplitud_absoluta <- maximas_absolutas - minimas_absolutas
    
    titulo <- paste0('Amplitud térmica absoluta en ',substr(archivo, 1, nchar(archivo) - 4),'.')
    
    mytabl <- obtener_mytable(as.data.frame(amplitud_absoluta), titulo,
                              colores = c("#008000","#ffffff","#cc0000"), dominio = c(5,50),
                              interactivo=TRUE)
    
    return(list("mytabl"= mytabl,
                "tabla"= amplitud_absoluta) )
    
  }
  
}

top_five <- function(archivo, variable, orden) {
  
  datos <- tabla_mensual(archivo, variable)$tabla
  
  datos_lista <- datos %>%
    mutate('Anio' = rownames(datos)) %>%
    pivot_longer(cols = !Anio, names_to = 'Mes', values_to = 'Temp')
  
  ifelse(orden == 'descendente',
         datos_ranking <- datos_lista %>%
           group_by(Mes) %>%
           arrange(desc(Temp), .by_group = TRUE) %>%
           mutate(Puesto = dense_rank( desc(Temp) )) %>%
           filter(Puesto  <= 5) %>%
           select(-Puesto) %>%
           group_by(Mes,Temp) %>%
           summarise('Año(s)' = paste0(Anio, collapse = ', ')) %>%
           group_by(Mes) %>%
           arrange(desc(Temp)) %>%
           mutate(Posicion = row_number()) %>%
           ungroup() %>%
           select(Mes, Posicion, Temp, `Año(s)`) %>%
           rename('Temperatura (°C)' = Temp),
         
         datos_ranking <- datos_lista %>%
           group_by(Mes) %>%
           arrange(Temp, .by_group = TRUE) %>%
           mutate(Puesto = dense_rank( Temp )) %>%
           filter(Puesto  <= 5) %>%
           select(-Puesto) %>%
           group_by(Mes,Temp) %>%
           summarise('Año(s)' = paste0(Anio, collapse = ', ')) %>%
           group_by(Mes) %>%
           arrange(Temp) %>%
           mutate(Posicion = row_number()) %>%
           ungroup() %>%
           select(Mes, Posicion, Temp, `Año(s)`) %>%
           rename('Temperatura (°C)' = Temp)
         )
  
  meses_ordenados <- c("Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic")
  
  tabla_final <- datos_ranking %>%
    mutate(Mes = factor(Mes, levels = meses_ordenados)) %>%
    arrange(Mes, Posicion)
  
  return(as.data.frame(tabla_final))
  
}

