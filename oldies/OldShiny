medias_estacionales <- function(archivo, variable) {
  
  datos <- obtenerDatos(archivo)
  
  datos_modif <- datos %>% mutate(V = ifelse(M==12,A+1,A)) #Hago esto para computar bien las medias del verano
  #No más de 15% de datos faltantes
  medias_verano <- datos_modif %>% filter(M %in% c(12,1,2)) %>% group_by(V) %>% 
    summarise(mean_values= if_else( n() >= 90 & sum(is.na( eval(parse(text=variable)) )) < 90*0.15 , mean( eval(parse(text = variable)) , na.rm=T ) , NA ) )
  
  medias_otoño <- datos_modif %>% filter(M %in% c(3,4,5)) %>% group_by(A) %>%
    summarise(mean_values= if_else( n() == 92 & sum(is.na( eval(parse(text=variable)) )) < 92*0.15 , mean( eval(parse(text = variable)) , na.rm=T ) , NA ) )
  
  medias_invierno <- datos_modif %>% filter(M %in% c(6,7,8)) %>% group_by(A) %>% 
    summarise(mean_values= if_else( n() == 92 & sum(is.na( eval(parse(text=variable)) )) < 92*0.15 , mean( eval(parse(text = variable)) , na.rm=T ) , NA ) )
  
  medias_primavera <- datos_modif %>% filter(M %in% c(9,10,11)) %>% group_by(A) %>% 
    summarise(mean_values= if_else( n() == 91 & sum(is.na( eval(parse(text=variable)) )) < 91*0.15 , mean( eval(parse(text = variable)) , na.rm=T ) , NA ) )

  tabla_final <- medias_verano %>% full_join(medias_otoño,by = c('V' = 'A')) %>% 
    full_join(medias_invierno, by = c('V' = 'A')) %>% full_join(medias_primavera, by = c('V' = 'A'))
  
  tabla <- as.data.frame(tabla_final)
  rownames(tabla) <- tabla[,1]
  tabla[,1:4] <- round(tabla[,1:4],1)
  tabla[,1] <- NULL
  colnames(tabla) <- c('Ver','Oto','Inv','Pri')
  
  nombre_parametro <- switch(variable,"Tmin"="Temperatura mínima media", "Tmax"="Temperatura máxima media")
  
  titulo <- paste0(nombre_parametro,' ', ' estacional', ' en ',substr(archivo, 1, nchar(archivo) - 4),'.')
  
  mytabl <- tabla |> gt() |>
    tab_header(title = md(paste0('**', titulo, '**'))) |>
    cols_add(Año = rownames(tabla),.before = 'Ver') |>
    fmt_number(columns = 2:5,decimals = 1) |>
    tab_style(style = list(cell_text(weight = 'bold')),locations = cells_body(columns = 1)) |>
    cols_width(c(2:5) ~ px(63)) |>
    cols_width(Año ~ px(54)) |>
    data_color(columns = c(2:5),method = 'numeric', palette = c("#8000ff","#62be7a","#ffeb84","#f8696b"), domain = c(-40,50)) |>
    tab_options(container.width = px(306)) |>
    opt_interactive(use_pagination = F,use_search = F)
  
  return(list("mytabl"=mytabl,
              "tabla"=tabla) )
}

