umbralesTodoRegistro <- function(archivo, comparacion, umbral) {
  datos <- obtenerDatos(archivo)
  
  if (comparacion == "Tmin <=") {
    tabla <- subset(datos, Tmin <= umbral)
  } else if (comparacion == "Tmin >=") {
    tabla <- subset(datos, Tmin >= umbral)
  } else if (comparacion == "Tmax <=") {
    tabla <- subset(datos, Tmax <= umbral)
  } else if (comparacion == "Tmax >=") {
    tabla <- subset(datos, Tmax >= umbral)
  }
  
  titulo <- paste0('Dias con ',comparacion,umbral,'°C en ',substr(archivo, 1, nchar(archivo) - 4),'.')
  
