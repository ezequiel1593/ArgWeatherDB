#lim = 0.9 significa que al menos se debe contar con el 90% de los datos en c/ período
grafComparacionDensidad <- function(archivo, variable, anio1, anio2, extension, lim = 0.9) {
  
  #Investigar una manera más 'eficiente' de hacer esto
  datos <- obtenerDatos(archivo)
  datos <- datos[,c('A','M','D',variable)]
  
  long_periodo1 <- length(seq(as.Date(paste0(anio1,'-01-01')),
                              as.Date(paste0(anio1 + extension - 1,'-12-31')),
                              by='day'))
  
  datos_periodo1 <- datos %>% filter((A >= anio1) & (A <= anio1 + extension - 1)) %>%
    mutate(periodo = as.factor(paste0(anio1,'-',anio1 + extension - 1)))
  
  if ( sum((!is.na(datos_periodo1[,4])) / long_periodo1) < lim ) {
    f <- ggplot() + annotate('text', x = 0.5, y = 0.5,
                             label = 'El período 1 no tiene datos suficientes.') +
      theme_void()
    return(f)
  }
  
  long_periodo2 <- length(seq(as.Date(paste0(anio2,'-01-01')),
                              as.Date(paste0(anio2 + extension - 1,'-12-31')),
                              by='day'))
  
  datos_periodo2 <- datos %>%  filter((A >= anio2) & (A <= anio2 + extension - 1)) %>%
    mutate(periodo = as.factor(paste0(anio2,'-',anio2 + extension - 1)))
  
  if ( sum((!is.na(datos_periodo2[,4])) / long_periodo2) < lim ) {
    f <- ggplot() + annotate('text', x = 0.5, y = 0.5,
                             label = 'El período 2 no tiene datos suficientes.') +
      theme_void()
    return(f)
  }
  
  datos_juntos <- bind_rows(datos_periodo1, datos_periodo2)
  
  set_blanket()
  f <- gg_density(data = datos_juntos, x = !!rlang::sym(variable), col = periodo,
                  alpha = 0.4, x_label = paste0(variable,' (°C)'), y_label = 'Densidad',
                  title = paste0(obtenerNombreBreve(archivo))) +
    theme(plot.title = element_text(hjust = 0.5),
          legend.position = 'bottom', legend.direction = 'horizontal', legend.title = element_blank())
  
  return(f)
    
  
}

grafHistograma <- function(archivo, variable, mes) {
  datos <- obtenerDatos(archivo)
  datos <- datos[,c('A','M','D',variable)]
  subdatos <- subset(datos, M == mes)
  
  limite_inferior <- floor(min(subdatos[,4],na.rm = T)/2) * 2
  limite_superior <- ceiling(max(subdatos[,4],na.rm = T)) * 2
  
  frecuencias <- table( cut(datos[,4],breaks = seq(limite_inferior,limite_superior,2), right = FALSE ) )
  frecuencias <- frecuencias[which(frecuencias != 0)]
  
  df <- data.frame(limites = factor(names(frecuencias), levels = names(frecuencias)), valores = as.vector(frecuencias))

  f <- ggplot(df, aes(x= limites, y= valores )) +
    geom_col(fill = 'steelblue') +
    labs(title = 'Frecuencias', x = 'Categorias', y = 'Frecuencias') +
    theme_minimal()
  f
}

