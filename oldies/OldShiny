graf_serie_temporal <- function(archivo, mes, variable, estadistica) {
  
  if (variable == 'Tmin') {
    DF_datos <- case_when(estadistica == 'media' ~ tabla_mensual(archivo,'tnm')$tabla,
                          estadistica == 'baja' ~ tabla_mensual(archivo,'tnn')$tabla,
                          estadistica == 'alta' ~ tabla_mensual(archivo,'tnx')$tabla,
                          estadistica == 'desvioest' ~ desvioEstandarMensual(archivo,'Tmin')$tabla,
                          estadistica == 'mediana' ~ medianaMensualTabla(archivo,'Tmin')$tabla)
  } else if (variable == 'Tmax') {
    DF_datos <- case_when(estadistica == 'media' ~ tabla_mensual(archivo,'txm')$tabla,
                          estadistica == 'baja' ~ tabla_mensual(archivo,'txn')$tabla,
                          estadistica == 'alta' ~ tabla_mensual(archivo,'txx')$tabla,
                          estadistica == 'desvioest' ~ desvioEstandarMensual(archivo,'Tmax')$tabla,
                          estadistica == 'mediana' ~ medianaMensualTabla(archivo,'Tmax')$tabla)
  }
  
  DF_datos <- DF_datos %>%
    select(mes) %>%
    mutate(anios = as.integer(rownames(DF_datos))) %>%
    rename(Temp = 1)
  
  #Gráfico
  nombre_parametro <- paste0(ifelse(estadistica == 'desvioest','Desvío estándar de la temperatura ','Temperatura '),
                             ifelse(variable == 'Tmin','mínima ','máxima '),
                             case_when(estadistica == 'media' ~ 'media',
                                       estadistica == 'baja' ~ 'más baja',
                                       estadistica == 'alta' ~ 'más alta',
                                       estadistica == 'desvioest' ~ '',
                                       estadistica == 'mediana' ~ 'mediana')
                             )
  
  nombre_mes <- switch(mes,"enero", "febrero", "marzo", "abril", "mayo", "junio",
                       "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre")
  titulo <- paste0(nombre_parametro, " - ",substrRight(archivo), " - ", nombre_mes, ".")
  
  set_blanket()
  f <- gg_line(data = DF_datos, x = anios, y = Temp,
               title = titulo, subtitle = 'Suavisado LOESS',
               linewidth = 1,
               y_label = 'Temperatura (°C)', x_label = 'Año') +
    #Elimino las comas de los millares del eje X
    scale_x_continuous(breaks = seq( floor(min(DF_datos$anios, na.rm = TRUE)/10) * 10 ,
                                     ceiling(max(DF_datos$anios, na.rm = TRUE)/10) * 10,
                                     by= 10) ) +
    geom_smooth(se = FALSE,colour = 'red',linetype = 'dashed',linewidth = 1)
  
  return(f)
}

grafico_media_movil <- function(archivo, ventana = 31, variable, anio_target) {
  
  #No más de 3 NA para calcular la media móvil, en un futuro quizás lo cambie a porcentaje
  mov_avg <- function(x, n = ventana, max_na = 3) {
    zoo::rollapply(x, width = n, function (w) {
      ifelse(sum(is.na(w)) <= max_na, mean(w, na.rm = TRUE), NA ) },
      fill = NA, align = 'center') } #La media móvil es centrada
  
  datos <- obtenerDatos(archivo)
  
  tablaFinal <- datos %>%
    select(A,M,D,!!variable) %>%
    filter(A >= 1960) %>% #Análisis a partir del año 1961 (necesito los de diciembre de 1960)
    mutate(media_movil = round(mov_avg( x = !!rlang::sym(variable) ),1)) %>%
    filter(!(M == 2 & D == 29)) %>% #Elimino los 29-feb
    mutate(dia_del_anio = yday(ymd(paste(A,M,D,sep = '-'))) )
  
  #Gráfico
  titulo <- paste0('Temperatura ',ifelse(variable == 'Tmin','mínima','máxima'),
                   ' media móvil - ', obtenerNombreBreve(archivo),
                   ' (',ifelse(min(tablaFinal$A) == 1960, 1961, min(tablaFinal$A)),
                   '-2025).')
  
  set_blanket()
  f <- gg_line(data = tablaFinal,
               x = dia_del_anio, y = media_movil,
               group = A, colour= 'black') +
    gghighlight::gghighlight(A == anio_target,
                             line_label_type = "sec_axis") + 
    labs(title = titulo,
         y = 'Temp. media móvil (°C)',
         subtitle = 'Ventana centrada de 31 días.' ) +
    scale_x_continuous(name = 'Días del año',
                       breaks = c(1,32,60,91,121,152,182,213,244,274,305,335),
                       labels = function(x) {
                         fecha <- as.Date('2025-01-01') + days(x -1)
                         format(fecha, '%d-%m') },
                       expand = c(0,0)) +
    theme(axis.text.x = element_text(angle = 90, vjust = 0.5),
          #Ver si mantengo esto del panel
          panel.grid.major.x = element_line(color = 'gray80'))
  
  return(f)

}

