tablaAnual <- function(archivo,anio){
  
  datos <- obtenerDatos(archivo)
  subdatos <- subset(datos, A==anio)
  
  #CAMBIAR ESTO AL FINALIZAR EL AÑO 2025!!
  if (anio == 2025) {
    fechas_completas <- tidyr::expand_grid(
      fecha = seq(as.Date('2025-01-01'), as.Date('2025-12-31'), by = 'day') ) %>%
      mutate(A = year(fecha), M = month(fecha), D = day(fecha)) %>%
      select(A,M,D) %>%
      mutate_all(as.integer)
    
    subdatos <- fechas_completas %>%
      left_join(subdatos, by = c('A','M','D'))
  }
  
  if (NROW(subdatos) == 0) {
    tabla <- data.frame("SD"= c("Sin datos para este año."))
    mytabl <- gt(data = tabla)
  } else {
    
    dividido <- split(subdatos[c('D','Tmin','Tmax')], subdatos$M)
    tablaFinal <- as.data.frame(dividido[[1]])
    for (i in 2:12) {
