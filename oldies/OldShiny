      data_color(columns = c(2:25),method = 'numeric', palette = c("#8000ff","#62be7a","#ffeb84","#f8696b"), domain = c(-40,50))
    
    meses <- c("Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic")
    
