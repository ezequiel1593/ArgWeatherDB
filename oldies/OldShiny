records_amplitud_termica <- function(archivo) {
  datos <- obtenerDatos(archivo)
  datos$Amplitud <- datos$Tmax - datos$Tmin
  datos$Fecha <- as.Date(paste0(datos$A,'-',datos$M,'-',datos$D), format = '%Y-%m-%d')
  
  records_minimos <- aggregate(datos,by=list(datos$M), function(x) min(x,na.rm = TRUE))
  fechas_min <- numeric(0)
  records_maximos <- aggregate(datos,by=list(datos$M), function(x) max(x,na.rm = TRUE))
  fechas_max <- numeric(0)
  
  for (mes in 1:12) {
    subdatos <- subset(datos, M == mes)
    posicion_fecha_min <- which(subdatos$Amplitud == records_minimos$Amplitud[mes])
    fechas_min[mes] <- as.character(paste(subdatos$Fecha[posicion_fecha_min], collapse = "\n"))
    
    posicion_fecha_max <- which(subdatos$Amplitud == records_maximos$Amplitud[mes])
    fechas_max[mes] <- as.character(paste(subdatos$Fecha[posicion_fecha_max], collapse = "\n"))
  }
  
  tabla <- data.frame("Mes"= c("Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic"),
                      "Mín"= records_minimos$Amplitud,
                      "Fecha_Min"= fechas_min,
                      "Máx"= records_maximos$Amplitud,
                      "Fecha_Max"= fechas_max)
  
  titulo <- paste0('Récords de amplitud térmica diaria en ', substr(archivo,1,nchar(archivo)-4) )
  
  mytabl <- tabla|> gt() |>
    tab_header(title = md(paste0('**', titulo, '**'))) |>
    fmt_number(columns = c(2,4),decimals = 1) |>
    tab_style(style = cell_text(weight = 'bold'),locations = cells_column_labels()) |>
    tab_style(style = cell_text(weight = 'bold'),locations = cells_body(columns = 1)) |>
    cols_width(c(3,5) ~ px(95)) |>
    cols_width(c(1,2,4) ~ px(40)) #|>
    #tab_options(container.width = px(210))
  
  return(mytabl)
}

